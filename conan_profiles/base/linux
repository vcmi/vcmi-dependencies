{% import 'vars.jinja' as vars %}

include(common)

[settings]
compiler=gcc
compiler.cppstd={{ vars.cppstd }}
compiler.libcxx=libstdc++
compiler.version=13
os=Linux

{{ vars.glaze_cppstd }}

[options]
qt/*:with_freetype=True
ffmpeg/*:avdevice=True
# fixing wayland-scanner not finding libiconv
libiconv/*:shared=False

[replace_requires]
# conflict with qt (xkbcommon 1.5.0)
xkbcommon/*:xkbcommon/1.6.0

[conf]
tools.system.package_manager:mode=install
tools.system.package_manager:sudo=True
